{
  "database": "flowerbase-demo",
  "collection": "todos",
  "schema": {
    "title": "todo",
    "bsonType": "object",
    "encryptMetadata": {
      "keyAlias": "prod-data-key"
    },
    "properties": {
      "title": {
        "encrypt": {
          "bsonType": "string",
          "algorithm": "AEAD_AES_256_CBC_HMAC_SHA_512-Random",
          "keyAlias": "dev-data-key"
        }
      },
      "secureNote": {
        "encrypt": {
          "bsonType": "string",
          "algorithm": "AEAD_AES_256_CBC_HMAC_SHA_512-Deterministic"
        }
      }
    }
  }
}